            "type": "command",
            "command": "/home/itec/emanuele/.agent-rules/scripts/paper-sync-reminder.py",
            "args": [
              "--outputs-dir", "outputs",
              "--paper-dir", "67a9ea6275d3d9785ce57026",
              "--summary-file", "run_summary.json",
              "--noun", "Runs"
            ]
          }
        ]
      }
    ]
