        "hooks": [
          {
            "type": "command",
            "command": "/home/itec/emanuele/.agent-rules/scripts/session-status.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
